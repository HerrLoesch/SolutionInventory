{
  "name": "solution-inventory-pwa",
  "version": "0.1.0",
  "description": "Solution Inventory - A questionnaire-based application for project assessment",
  "author": "Hendrik Lösch <loeschhendrik@googlemail.com>",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "npx playwright install",
    "dev": "vite",
    "build": "npx playwright test && vite build",
    "preview": "vite preview",
    "test-export": "node scripts/test_export_node.js data/sample_export.json solution_inventory_test.xlsx",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build --mode electron && electron-builder",
    "electron:preview": "vite build --mode electron && electron .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "pinia": "^2.3.1",
    "vue": "^3.3.4",
    "vuetify": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^4.4.9",
    "vite-plugin-pwa": "^0.14.7"
  },
  "build": {
    "appId": "com.solutioninventory.app",
    "productName": "Solution Inventory",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Hendrik Lösch <loeschhendrik@googlemail.com>"
    }
  }
}
